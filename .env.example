# Copy this file to .env and fill in real values. Do NOT commit .env.

# PostgreSQL connection string used by server.js (pg Pool)
DATABASE_URL=postgres://user:password@localhost:5432/trivia

# Anthropic API key for generating trivia questions (Claude)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Secret used to sign JWT auth tokens — use a long random string
JWT_SECRET=change_me_to_a_long_random_secret

# Port the server listens on
PORT=3000

# Email of the account that should be granted admin privileges on boot
ADMIN_EMAIL=admin@example.com
